rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // User's soil samples
      match /soil_samples/{sampleId} {
        allow read, write: if isOwner(userId);
      }
      
      // User's maintenance tasks
      match /maintenance_tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }
      
      // User's custom crops
      match /custom_crops/{cropId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Global crops collection (default + custom)
    match /crops/{cropId} {
      // Anyone can read crops
      allow read: if true;
      
      // Only authenticated users can add custom crops
      allow create: if isAuthenticated() && 
                       request.resource.data.isCustom == true &&
                       request.resource.data.userId == request.auth.uid;
      
      // Users can only update/delete their own custom crops
      allow update, delete: if isAuthenticated() && 
                               resource.data.isCustom == true &&
                               resource.data.userId == request.auth.uid;
    }
    
    // Soil samples (top-level collection)
    match /soil_samples/{sampleId} {
      allow read, write: if isAuthenticated() && 
                            resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
    }
    
    // Maintenance tasks (top-level collection)
    match /maintenance_tasks/{taskId} {
      allow read, write: if isAuthenticated() && 
                            resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
    }
    
    // Market price cache (optional - if caching USDA data)
    match /market_prices/{priceId} {
      allow read: if true;
      allow write: if false; // Only backend can write
    }
  }
}
