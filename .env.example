# SoilSmart Environment Configuration
# Copy this to .env and fill in your values (if using flutter_dotenv package)

# Firebase Configuration
# Note: FlutterFire CLI auto-generates firebase_options.dart
# This is only needed if you want additional environment-specific configs

# App Configuration
APP_NAME=SoilSmart
APP_VERSION=1.0.0

# API Endpoints
USDA_AMS_API_URL=https://marsapi.ams.usda.gov/services/v1.2/reports

# Feature Flags (future use)
ENABLE_BLUETOOTH=true
ENABLE_MARKET_PRICES=true
ENABLE_MAINTENANCE=true
ENABLE_PDF_UPLOAD=false  # Phase 2 feature
ENABLE_MESH_NODES=false  # Phase 4 feature

# Debug Settings
ENABLE_LOGGING=true
LOG_LEVEL=info

# External Services (future integrations)
# WEATHER_API_KEY=your_openweather_api_key
# GOOGLE_MAPS_API_KEY=your_maps_api_key

# Notes:
# - USDA AMS API requires no API key (public endpoint)
# - Firebase credentials managed via firebase_options.dart
# - Add this file to .gitignore if using real API keys
